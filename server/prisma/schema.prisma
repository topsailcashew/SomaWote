generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lesson {
  id        String   @id @default(cuid())
  title     String
  grade     String
  subject   Subject
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssessmentResult {
  id         String   @id @default(cuid())
  studentId  String
  responses  Json
  score      Float?
  createdAt  DateTime @default(now())
}

model Student {
  id           String  @id @default(cuid())
  name         String
  grade        String
  disabilities String[]
  teacherId    String?
  teacher      Teacher? @relation(fields: [teacherId], references: [id])
}

model Teacher {
  id       String    @id @default(cuid())
  name     String
  school   String
  students Student[]
}

enum Subject {
  LITERACY
  NUMERACY
  UDL
  ADVOCACY
}
